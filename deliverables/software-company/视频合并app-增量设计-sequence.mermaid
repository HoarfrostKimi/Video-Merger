%% 视频合并App 增量设计 — 序列图集合
%% 对应《视频合并app-增量设计-2026-07-06.md》Part A §4

%% ---- 4.1 旧 userData 配置迁移时序（A3） ----
sequenceDiagram
    participant A as app (Electron)
    participant M as UserDataMigrator
    participant FS as 文件系统
    participant C as ConfigService

    A->>A: app.whenReady()
    A->>M: migrateLegacyUserData()
    M->>M: resolveUserDataPath()  // 默认 app.getPath('userData')
    Note over M: 若 process.env.VIDEO_MERGE_USER_DATA 设了则用其覆盖
    M->>M: getLegacyConfigPath()  // join(__dirname, '../../user-data', 'config.json')
    M->>FS: existsSync(legacyConfig)
    alt 旧配置存在
        M->>FS: readFileSync(legacyConfig)
        M->>FS: writeFileSync(newUserDir/config.json)
        M->>FS: unlinkSync(legacyConfig)
        M-->>A: 迁移完成（旧目录可保留为空）
    else 不存在
        M-->>A: 无需迁移
    end
    A->>C: createWindow()  // 之后 loadConfig 落到新默认 userData

%% ---- 4.2 异步扫描时序（B1） ----
sequenceDiagram
    participant R as Home.tsx
    participant P as preload(api)
    participant H as main(scan:flvFiles)
    participant S as ScanService
    participant FS as fs.promises

    R->>P: scanFlvFiles(folder, maxHours)
    P->>H: ipc invoke scan:flvFiles
    H->>H: validateFolderPath(folder)  // A4
    H->>S: scanFlvFiles(folder, maxHours)
    S->>FS: readdir(folder, {withFileTypes:true})
    loop 递归子目录（异步）
        FS-->>S: entries
        S->>FS: stat(entry) 仅对文件
        S->>S: parseFileName + push FileInfo
    end
    S->>S: groupFiles() + hasMergedVideo()(异步)
    S-->>H: ScanResult
    H-->>P: {success,data}
    P-->>R: ScanResult

%% ---- 4.3 真实时长进度时序（B2） ----
sequenceDiagram
    participant R as Home.tsx
    participant P as preload(api)
    participant H as main(video:merge)
    participant F as FfmpegService
    participant FF as FFmpeg 子进程

    R->>P: mergeVideos(paths, out)
    P->>H: ipc invoke video:merge
    H->>F: mergeVideos(paths, out, onProgress)
    F->>F: 探测锁定文件 (openSync)
    loop 每个可访问源文件
        F->>F: ffmpegProbe(f)  // 真实 duration
    end
    F->>F: totalDuration = Σ duration
    alt totalDuration > 0
        F->>FF: spawn ffmpeg -f concat -c copy
        FF-->>F: stderr time=HH:MM:SS
        F->>F: percent = min(cur/total*100, 99.9)
        F->>H: onProgress(percent)
        H->>H: mergeProgress = percent
        R->>P: getProgress()(每 300ms 轮询)
        P->>H: ipc progress:get
        H-->>P: {mergeProgress}
        P-->>R: 平滑进度
    else totalDuration == 0（探针全失败）
        F->>F: 回退字节估算 totalDuration(标记不确定)
        Note over F,R: 进度仍以真实时间为准，仅在无时间信息时显示占位
    end
    FF-->>F: exit 0
    F->>F: rename temp -> out
    F-->>H: resolve(warning?)

%% ---- 4.4 IPC 校验 + preload 调用时序（A4 / A5 / C2） ----
sequenceDiagram
    participant R as Home.tsx
    participant P as preload(api)
    participant M as main(safeHandle)

    R->>P: api.scanFlvFiles(folder, hours)
    P->>P: invokeApi~ScanResult~('scan:flvFiles', folder, hours)
    P->>M: ipcRenderer.invoke('scan:flvFiles', ...)
    M->>M: ALLOWED_IPC_CHANNELS.has('scan:flvFiles')?  // 白名单守卫
    alt 非法 channel
        M-->>P: {success:false, message:'非法调用'}
    else 合法
        M->>M: handler 内 validateFolderPath(folder)
        alt 校验失败
            M-->>P: {success:false, message:'路径非法'}
        else 通过
            M-->>P: {success:true, data}
        end
    end
    P->>P: result.success? return data : throw Error(message)
    P-->>R: ScanResult 或抛错
