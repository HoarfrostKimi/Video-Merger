#!/bin/sh
# ============================================================
# Git Pre-Commit 钩子（方案B：检查标记文件）
# 功能：在每次 git commit 前检查测试和质量标记文件是否存在
# 通过 → 允许提交
# 失败 → 拒绝提交
# 跳过方式：git commit --no-verify
# ============================================================

echo ""
echo "=========================================="
echo "  视频合并app - 提交前质量守卫"
echo "=========================================="
echo ""

# 获取项目根目录
PROJECT_ROOT=$(git rev-parse --show-toplevel)
QUALITY_DIR="$PROJECT_ROOT/.quality"

# ============ 第一步：检查测试标记 ============
echo "[1/2] 检查单元测试标记..."
echo ""

if [ -f "$QUALITY_DIR/test-passed.marker" ]; then
    echo "✅ 单元测试标记存在，测试已通过"
else
    echo "❌ 未找到测试通过标记文件"
    echo ""
    echo "=========================================="
    echo "  请先运行 test-specialist agent 生成测试标记！"
    echo "=========================================="
    echo ""
    echo "操作建议："
    echo "  1. 对我说 \"跑测试\" 或 \"帮我提交代码\""
    echo ""
    exit 1
fi

echo ""

# ============ 第二步：检查质量标记 ============
echo "[2/2] 检查质量检查标记..."
echo ""

if [ -f "$QUALITY_DIR/quality-passed.marker" ]; then
    echo "✅ 质量检查标记存在，质量检查已通过"
else
    echo "❌ 未找到质量检查通过标记文件"
    echo ""
    echo "=========================================="
    echo "  请先运行 quality-engineer agent 生成质量标记！"
    echo "=========================================="
    echo ""
    echo "操作建议："
    echo "  1. 对我说 \"质量检查\" 或 \"帮我提交代码\""
    echo ""
    exit 1
fi

echo ""
echo "=========================================="
echo "  所有检查通过，允许提交！"
echo "=========================================="
echo ""

# ============ 第三步：清理标记文件（防止用旧通行证）============
echo "[3/3] 清理旧的标记文件..."
rm -f "$QUALITY_DIR"/*.marker
echo "✅ 已清理标记文件，下次提交需重新检查"
echo ""

exit 0
